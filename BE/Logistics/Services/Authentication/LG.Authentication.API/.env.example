# Copy to .env and fill in real values — never commit .env to git

# Database
DATABASE_URL=Host=localhost;Port=5432;Database=muaho_auth;Username=postgres;Password=CHANGE_ME

# JWT
Jwt__SecretKey=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS
Jwt__Issuer=muaho-api
Jwt__Audience=muaho-client
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=7

# CORS
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:5173
