# Copy file này thành .env và điền giá trị thực — KHÔNG commit .env lên git

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL local
DATABASE_URL=Host=localhost;Port=5432;Database=muaho_mod2;Username=postgres;Password=CHANGE_ME

# ── JWT (dùng chung secret với Auth service và Module1) ───────────────────────
Jwt__SecretKey=CHANGE_ME_USE_LONG_RANDOM_STRING_MIN_32_CHARS

# ── CORS ──────────────────────────────────────────────────────────────────────
Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:5173
